# Copy this file to .env before running docker compose.

# Container timezone
TZ=Asia/Ho_Chi_Minh
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Ho_Chi_Minh

# External infrastructure
DB_HOST=your-mysql-host
DB_PORT=3306
DB_JDBC_URL=jdbc:mysql://your-mysql-host:3306/your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_CACHE_TTL=3600

KAFKA_URLS=your-kafka-host:9092
KAFKA_TOPIC_MARKET_DATA=market-data
KAFKA_TOPIC_WEBHOOKS=market-payment
KAFKA_TOPIC_REST=market-rest
KAFKA_TOPIC_INGESTION=market-ingestion
KAFKA_TOPIC_INGESTION_REPLY=
KAFKA_REQUEST_TIMEOUT_MS=15000

MQTT_URL=tcp://your-mqtt-host:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_MARKET_DATA=market-data

# Required by market-collector
DATAFEED_TOKENURL=wss://datafeed-lts-krx.dnse.com.vn:443/wss
DATAFEED_INVERSTORURL=
DATAFEED_WEBSOCKETURL=
DATAFEED_USERNAME=
DATAFEED_PASSWORD=

# Required by realtime/webhooks payment flows
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Optional mail settings for market-realtime
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Public URLs baked into the frontend image at build time.
# Point these to HAProxy or another public proxy when Java services are not published directly.
VITE_API_BASE_URL=http://localhost:3001
VITE_INGESTION_API_BASE_URL=http://your-ingestion-http-proxy
VITE_MQTT_BROKER_URL=ws://your-mqtt-websocket-host:8083/mqtt
VITE_MQTT_TOPIC=market-data

# Optional domain used by realtime links/emails
APP_DOMAIN=localhost
